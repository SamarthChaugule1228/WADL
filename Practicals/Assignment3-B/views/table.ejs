<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <style>
        table { border-collapse: collapse; margin: 20px auto; }
        th, td { border: 1px solid black; padding: 10px; text-align: center; }
        th { background-color: lightgray; }
    </style>
</head>
<body>

<h2 style="text-align:center;"><%= title %></h2>

<p style="text-align:center;">Total: <%= songs.length %></p>

<table>
    <tr>
        <th>Song</th>
        <th>Film</th>
        <th>Director</th>
        <th>Singer</th>
        <th>Actor</th>
        <th>Actress</th>
    </tr>

    <% songs.forEach(song => { %>
        <tr>
            <td><%= song.songname %></td>
            <td><%= song.film %></td>
            <td><%= song.music_director %></td>
            <td><%= song.singer %></td>
            <td><%= song.actor || '' %></td>
            <td><%= song.actress || '' %></td>
        </tr>
    <% }) %>

</table>

</body>
</html>